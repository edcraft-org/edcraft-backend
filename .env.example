# ============================================================================
# EdCraft Backend Environment Configuration Template
# ============================================================================
# Copy this file to create environment-specific configuration:
#   - .env.development  (for local development)
#   - .env.test         (for running tests)
#   - .env.production   (for production - or use system env vars)
#
# Then set APP_ENV environment variable to select which config to use:
#   export APP_ENV=development
#   export APP_ENV=test
#   export APP_ENV=production
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
# Application environment - determines which .env.{APP_ENV} file to load
# Options: development, production, test
APP_ENV=development

# Application metadata
APP_NAME=EdCraft Backend API
APP_VERSION=0.1.0

# ============================================================================
# Database Configuration
# ============================================================================
# Main database URL
# Format: postgresql+asyncpg://username:password@host:port/database_name

DATABASE_URL=postgresql+asyncpg://edcraft_user:edcraft_password@localhost:5432/edcraft

# Enable SQL query logging (auto-enabled in development, disabled in production)
# DATABASE_ECHO=true

# ============================================================================
# PostgreSQL Container Settings (for docker-compose.yml)
# ============================================================================
# These values are used when running the local PostgreSQL containers

# Database container
POSTGRES_DB=edcraft
POSTGRES_USER=edcraft_user
POSTGRES_PASSWORD=edcraft_password

# ============================================================================
# CORS Configuration
# ============================================================================
# JSON array of allowed origins
# DEVELOPMENT:
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# PRODUCTION (update with your actual frontend domain):
# CORS_ORIGINS=["https://edcraft.example.com"]

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Server Configuration
# ============================================================================
# Server host
SERVER_HOST=127.0.0.1

# Server port
SERVER_PORT=8000

# Logging level
# Options: debug, info, warning, error, critical
LOG_LEVEL=info

# ============================================================================
# JWT Configuration
# ============================================================================
# Secret key for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ISSUER=edcraft
JWT_AUDIENCE=edcraft
JWT_KID=1

# ============================================================================
# Session Configuration
# ============================================================================
# Secret key for signing session cookies (OAuth flow) — generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret-key-here

# ============================================================================
# OAuth Google
# ============================================================================
# Set after creating a Google Cloud OAuth 2.0 client
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# ============================================================================
# OAuth GitHub
# ============================================================================
# Set after creating a GitHub OAuth app
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8000/auth/oauth/github/callback

# ============================================================================
# Auth
# ============================================================================
PASSWORD_MIN_LENGTH=12
FRONTEND_URL=http://localhost:5173

# ============================================================================
# Email Configuration
# ============================================================================
# SMTP server settings
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your-email@gmail.com
# EMAIL_SMTP_PASSWORD=your-app-password-here

# From address
EMAIL_FROM_EMAIL=noreply@edcraft.com
EMAIL_FROM_NAME=EdCraft

# Enable/disable email sending (set to False for dev/test environments)
EMAIL_ENABLED=true

# Email verification token expiration (in hours)
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ============================================================================
# Nomad Job Queue Configuration
# ============================================================================
# Host where the Nomad agent is running.
# Development: use ip addr show eth0 | grep 'inet ' | awk '{print $2}' | cut -d/ -f1 to get the local IP address
# Production: the Nomad cluster address
NOMAD_HOST=127.0.0.1

# Nomad HTTP API port (default: 4646)
NOMAD_PORT=4646

# Nomad ACL token — leave blank in dev (-dev mode has ACLs disabled)
# NOMAD_TOKEN=

# Nomad namespace for job isolation (optional)
# NOMAD_NAMESPACE=

# Datacenters where jobs can be scheduled (must match Nomad server config)
NOMAD_DATACENTERS=["dc1"]

# Resource limits per worker task
NOMAD_CPU_MHZ=500
NOMAD_MEMORY_MB=512

# Base URL the worker container uses to POST results back to FastAPI.
# Must be reachable from inside a Nomad-spawned Docker container.
# Development: use the Docker compose service name
# Production: use the public or internal backend URL
NOMAD_CALLBACK_BASE_URL=http://edcraft-backend:8000

# Docker image to run as the worker (same image as the API server)
# Development: locally built image
# Production: pinned registry tag, e.g. ghcr.io/edcraft/edcraft-backend:v1.2.3
NOMAD_CONTAINER_IMAGE=edcraft-backend:local
